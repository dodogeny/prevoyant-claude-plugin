# ============================================================
# Prevoyant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Claude Code loads .env automatically from the project root,
# so every tool (the skill, MCP server, polling script) picks
# up credentials from this one file.
#
# .env is listed in .gitignore and will never be committed.
# Share secrets with teammates via 1Password or your secrets manager.
# ============================================================


# ────────────────────────────────────────────────────────────
# REPOSITORY (required)
# ────────────────────────────────────────────────────────────
# Absolute path to the local clone of the codebase you are
# working on. The skill creates branches and searches files here.

PRX_REPO_DIR=/absolute/path/to/your/repo


# ────────────────────────────────────────────────────────────
# JIRA (required)
# ────────────────────────────────────────────────────────────
# The MCP server (mcp-atlassian) and the polling script both
# read these from the environment — no other config file needed.
#
# Get your API token: https://id.atlassian.com/manage-profile/security/api-tokens

JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=firstname.lastname@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token-here


# ────────────────────────────────────────────────────────────
# KNOWLEDGE BASE (optional)
# ────────────────────────────────────────────────────────────
# Leave PRX_KB_MODE unset for single-machine use (local mode, zero setup).
# Set to "distributed" to share the KB across your team via a private git repo.

# Optional: hosted URL of your codebase (e.g. GitHub / Bitbucket / GitLab).
# Used to cross-check KB file:line references against the live branch.
# Omit to skip the cross-check.
# PRX_SOURCE_REPO_URL=https://github.com/myorg/myrepo

# "local" (default) or "distributed"
# PRX_KB_MODE=local

# Local mode only: override the default KB path.
# Default: $HOME/.prevoyant/knowledge-base
# PRX_KNOWLEDGE_DIR=/your/custom/kb/path

# Distributed mode only: URL of your team's private KB git repository.
# Required when PRX_KB_MODE=distributed.
# PRX_KB_REPO=git@github.com:yourorg/team-kb.git

# Distributed mode only: local clone path for the KB repo.
# Default: $HOME/.prevoyant/kb
# PRX_KB_LOCAL_CLONE=$HOME/.prevoyant/kb

# Distributed mode only: AES-256-CBC encryption passphrase.
# Optional — omit to push plain Markdown (fine when the repo is private).
# If set, all KB files are encrypted before each push and decrypted at session start.
# Never commit this value. Share via 1Password or your secrets manager.
# PRX_KB_KEY=your-strong-secret-passphrase

# ── Real-time KB sync — Redis doorbell, Git mail carrier ─────────────────────
# Propagates KB updates across all connected machines the moment a session ends.
# Flow: Machine A finishes → git push (KB files, private repo) → XADD to Upstash
#       (tiny ~100-byte notification: machine name, ticket key, commit hash).
#       Every other machine is polling XREAD and immediately does git pull --rebase.
#       No KB content ever touches Redis. Git carries the actual files.
# Requires PRX_KB_MODE=distributed and Upstash credentials below.
# Sign up free at https://upstash.com/ — free tier is more than enough.

# Enable real-time KB sync. Default: N (disabled).
# PRX_REALTIME_KB_SYNC=N

# Upstash Redis REST URL. Copy from console.upstash.com → your database → REST API.
# PRX_UPSTASH_REDIS_URL=https://your-endpoint.upstash.io

# Upstash Redis REST token. Copy from the same REST API panel. Never commit this.
# PRX_UPSTASH_REDIS_TOKEN=your-token-here

# Override the machine name used in sync notifications. Defaults to os.hostname().
# Useful in Docker / cloud VMs where the hostname is unstable across restarts.
# PRX_KB_SYNC_MACHINE=my-machine-name

# How often each machine polls Redis for new KB notifications. Default: 10 (seconds).
# PRX_KB_SYNC_POLL_SECS=10

# What triggers an outbound KB notification on this machine:
#   session    — SKILL.md writes ~/.prevoyant/.kb-updated after git push → XADD.
#                kb-sync.js never touches git. Clean handshake between bash and Node.
#   filesystem — Watches the KB dir for .md file changes (manual edits outside sessions).
#                kb-sync.js does git add / commit / push → XADD when changes are detected.
#   both       — Both triggers active simultaneously.
# Default: session
# PRX_KB_SYNC_TRIGGER=session

# How many seconds to wait after the last filesystem change before committing and pushing.
# Only applies when PRX_KB_SYNC_TRIGGER=filesystem or both. Default: 3.
# PRX_KB_SYNC_DEBOUNCE_SECS=3


# ────────────────────────────────────────────────────────────
# AGENT MEMORY INDEX (optional)
# ────────────────────────────────────────────────────────────
# Indexes learnings, surprises, and notes from session memory files and
# injects only the most relevant ones per session. ~96% token reduction
# over loading full session excerpts.
#
# Two backends — enable one or both:
#   JSON  — local file index at ~/.prevoyant/memory/index.json. Zero setup.
#   Redis — team-shared store via Redis. All developers share one index.
#           Redis takes priority; JSON stays warm as a hot-standby.
#
# JSON backend (local fallback):
# PRX_MEMORY_INDEX_ENABLED=Y
# PRX_MEMORY_LIMIT=15

# Redis backend (team-shared, primary):
# PRX_REDIS_ENABLED=Y
#
# Redis URL — use rediss:// for TLS (required for Upstash).
# To reuse your existing Upstash instance:
#   1. Open Upstash Console → your database → Connect → ioredis tab
#   2. Copy the rediss:// URL — it contains the Redis password (different from
#      the REST token in PRX_UPSTASH_REDIS_TOKEN above)
#   3. Paste it here. Leave PRX_REDIS_PASSWORD blank.
# PRX_REDIS_URL=rediss://default:<redis-password>@<host>:6379
# PRX_REDIS_PASSWORD=
# PRX_REDIS_PREFIX=prx:mem:
# PRX_REDIS_TTL_DAYS=0


# ────────────────────────────────────────────────────────────
# AGENT PERSONAL MEMORY — basic-memory MCP (optional)
# ────────────────────────────────────────────────────────────
# When enabled, each of the 7 agents (Morgan, Alex, Sam, Jordan,
# Henk, Riley, Bryan) gets a personal basic-memory MCP project
# that compounds individual knowledge across sessions — calibration
# data, corrected assumptions, and recurring surprises that belong
# to the agent rather than the shared KB.
# Requires: uvx (already installed for Jira MCP)
#
# Enable per-agent personal memory via basic-memory MCP. Default: N.
# PRX_BASIC_MEMORY_ENABLED=N
#
# Directory where basic-memory stores per-agent note databases.
# Default: $HOME/.prevoyant/personal-memory — kept OUTSIDE any KB clone
# so personal memory stays local to each developer's machine and is
# never accidentally pushed via git when the shared KB syncs.
# Override only if you have a specific reason to relocate it.
# BASIC_MEMORY_HOME=$HOME/.prevoyant/personal-memory


# ────────────────────────────────────────────────────────────
# REPORT OUTPUT (optional)
# ────────────────────────────────────────────────────────────
# Folder where PDF/HTML analysis reports are saved.
# Default: $HOME/.prevoyant/reports
# The folder is created automatically if it does not exist.

# CLAUDE_REPORT_DIR=/your/custom/reports/path


# ────────────────────────────────────────────────────────────
# AUTOMATION (optional)
# ────────────────────────────────────────────────────────────
# Set AUTO_MODE=Y to run the full workflow without any interactive
# prompts, confirmation gates, or permission asks. Safe defaults
# are applied at every gate. The fix is proposed AND automatically
# applied to the newly created feature branch.
# Default: N (interactive mode — prompts at each gate).

# AUTO_MODE=N

# Set FORCE_FULL_RUN=Y to force every step to execute in full even when
# the ticket has been analysed in a prior session. Without this flag the
# skill may condense steps 1–12 into a summary on repeat runs.
# Useful when replaying a ticket to get a completely fresh analysis.
# Default: N

# FORCE_FULL_RUN=N


# ────────────────────────────────────────────────────────────
# OUTPUT VERBOSITY (optional)
# ────────────────────────────────────────────────────────────
# Controls how much panel dialogue appears in the terminal.
# The PDF report always contains full content regardless of this setting.
#   full    → all panel dialogue, debate rounds, check-ins (default)
#   compact → structured blocks intact; narrative condensed to bullets
#   minimal → structured blocks only; no panel narrative

# PRX_REPORT_VERBOSITY=full


# ────────────────────────────────────────────────────────────
# JIRA PROJECT SCOPE (optional)
# ────────────────────────────────────────────────────────────
# Jira project key to scope ticket polling.
# When set, poll-jira.sh adds `project = {PRX_JIRA_PROJECT}` to the JQL
# so only tickets from that project trigger automated analysis.
# Omit to poll all projects assigned to currentUser().

# PRX_JIRA_PROJECT=IV


# ────────────────────────────────────────────────────────────
# ATTACHMENT SIZE LIMIT (optional)
# ────────────────────────────────────────────────────────────
# Maximum size in MB for non-image attachments (logs, dumps, XML, etc.).
# Set to 0 (or leave unset) for no limit — all attachments are downloaded
# and analysed regardless of size.
# Images/screenshots are always read regardless of this setting.
# Example: PRX_ATTACHMENT_MAX_MB=25  (skip non-image files > 25 MB)

# PRX_ATTACHMENT_MAX_MB=0


# ────────────────────────────────────────────────────────────
# EMAIL DELIVERY (optional)
# ────────────────────────────────────────────────────────────
# When PRX_EMAIL_TO is set, the analysis/review report is emailed
# automatically after it is saved, and a notification is sent for
# each newly assigned Jira ticket (via the polling script).
# Uses Python 3's built-in smtplib — no extra packages needed.
#
# Leave PRX_EMAIL_TO unset (or remove the line) to disable email entirely.

# Recipient address. Set this to enable email delivery.
# PRX_EMAIL_TO=recipient@example.com

# SMTP server hostname.
# Gmail:       smtp.gmail.com
# Outlook/365: smtp.office365.com
# PRX_SMTP_HOST=smtp.gmail.com

# SMTP port. Default: 587 (STARTTLS). Use 465 for SSL-only servers.
# PRX_SMTP_PORT=587

# SMTP login username (usually your email address).
# PRX_SMTP_USER=you@gmail.com

# SMTP password or app password.
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
#        (required when 2-Step Verification is enabled)
# Outlook/365: use your normal Microsoft 365 password (or app password if MFA is enforced)
# PRX_SMTP_PASS=your-app-password-here


# ────────────────────────────────────────────────────────────
# BRYAN — SCRUM MASTER / SKILL UPGRADES (optional)
# ────────────────────────────────────────────────────────────
# Bryan observes every session and proposes one SKILL.md improvement
# per session (Step 14 / R10). Disabled by default — set PRX_INCLUDE_SM_IN_SESSIONS_ENABLED=Y
# to activate. After unanimous team consensus, the change is queued.
# Once PRX_SKILL_UPGRADE_MIN_SESSIONS sessions with an approved change
# have accumulated, Bryan commits and pushes them to the plugin repo's main branch.

# Enable Bryan's retrospective. Default: N (disabled).
# PRX_INCLUDE_SM_IN_SESSIONS_ENABLED=N

# Number of sessions before pushing approved changes to main. Default: 3.
# Set to 1 to push after every approved session.
# PRX_SKILL_UPGRADE_MIN_SESSIONS=3

# Sessions between full SKILL.md compaction passes.
# On compaction sessions Bryan deep-reviews the entire file to eliminate
# redundancy and compress verbose prose. Requires all five team members to approve.
# Default: 10
# PRX_SKILL_COMPACTION_INTERVAL=10

# Monthly Claude subscription budget in USD.
# Actual token costs are measured using ccusage (https://www.npmjs.com/package/ccusage),
# which reads Claude Code's local JSONL logs — no network call, no auth needed.
# At every session start, scripts/check-budget.sh runs ccusage and injects the
# current month's actual spend into Claude's context, warning at ⚠️ >80% and ❌ ≥100%.
# Step 11 / R7 also uses ccusage to report the per-session cost delta.
# Budget resets on the 1st of each calendar month.
# Default: 20.00 (standard Claude Pro monthly subscription)

# PRX_MONTHLY_BUDGET=20.00

# PRX_JOB_TIMEOUT_MINS — kill any job still running after this many minutes.
# Set to 0 (default) to disable. Useful to prevent runaway sessions eating budget.
# PRX_JOB_TIMEOUT_MINS=0

# PRX_WEBHOOK_URL — POST job lifecycle events to this URL (Slack/Discord/Teams/custom).
# Leave unset to disable.
# PRX_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# PRX_WEBHOOK_EVENTS — comma-separated list of event types that trigger the webhook.
# Default: ticket_completed,ticket_failed,ticket_interrupted
# PRX_WEBHOOK_EVENTS=ticket_completed,ticket_failed,ticket_interrupted


# ────────────────────────────────────────────────────────────
# AMBIENT AGENT — WEBHOOK SERVER (optional)
# ────────────────────────────────────────────────────────────
# The Node.js server in server/ provides two capabilities:
#   1. Real-time: receives Jira webhook events and triggers analysis immediately.
#   2. Scheduled: runs poll-jira.sh on a configurable day interval as a fallback.
#
# To start the server:
#   cd server && npm install && npm start
#
# WEBHOOK_PORT — port the Express server listens on. Default: 3000.
# WEBHOOK_PORT=3000

# WEBHOOK_SECRET — token appended to the webhook URL you register in Jira.
# In Jira: Project settings → Webhooks → URL: http://your-server:3000/jira-events?token=YOUR_SECRET
# Leave empty to skip token validation (only safe on a private network).
# WEBHOOK_SECRET=your-strong-secret-here

# WEBHOOK_POLL_INTERVAL_DAYS — run poll-jira.sh every N days as the primary (cron) trigger.
# Cron is the default heartbeat; the Jira webhook accelerates real-time delivery on top of it.
# Set to 0 (or leave unset) to disable scheduled polling entirely.
# Fractional values work: 0.5 = every 12 hours, 7 = weekly.
# WEBHOOK_POLL_INTERVAL_DAYS=1

# PRX_HERMES_ENABLED — set to Y to delegate webhook reception and scheduling to a local
# Hermes gateway (https://hermes-agent.org). When enabled:
#   • POST /jira-events is NOT registered (Hermes is the front door for Jira events)
#   • POST /internal/enqueue is exposed for Hermes to hand jobs into the queue
#   • WEBHOOK_POLL_INTERVAL_DAYS is ignored — Hermes owns the cron schedule
#   • A one-time startup poll still runs to recover tickets missed while offline
# Default: N (Prevoyant Server operates standalone — cron poll + optional Jira webhook).
# PRX_HERMES_ENABLED=N

# PRX_HERMES_SECRET — shared secret Hermes must send in the X-Hermes-Secret header
# when calling POST /internal/enqueue. Leave empty to skip validation (private network only).
# PRX_HERMES_SECRET=your-hermes-secret-here

# PRX_HERMES_GATEWAY_URL — base URL of the Hermes gateway process. Prevoyant Server pushes
# job results (success/failed/interrupted) to POST <gateway>/prevoyant/result so Hermes can
# deliver them to Telegram, Slack, Discord, or any configured platform.
# Default: http://localhost:8080 (Hermes default port).
# PRX_HERMES_GATEWAY_URL=http://localhost:8080

# PRX_HERMES_JIRA_WRITEBACK — set to Y to automatically post a Jira comment on each ticket
# when Prevoyant analysis completes, fails, or is interrupted. Uses JIRA_URL / JIRA_USERNAME /
# JIRA_API_TOKEN credentials. Only active when PRX_HERMES_ENABLED=Y.
# PRX_HERMES_JIRA_WRITEBACK=N

# PRX_HERMES_KB_WRITEBACK_ENABLED — tri-state, controls POST /internal/kb/insights:
#   N    — endpoint returns 403 (feature off).
#   AUTO — Hermes is the judge (it's already an LLM with cross-ticket context).
#          Per the deployed SKILL.md, Hermes self-scores every insight on 5
#          criteria 0–10 and only posts when self-score >= 7. Prevoyant runs a
#          cheap heuristic alongside as a sanity check; both confident →
#          auto-approved + indexed; both reject → auto-rejected; they disagree
#          → human reviews. No external API call; no API key required. DEFAULT.
#   Y    — Bypass the AI judge — every insight requires a human approve/reject
#          click via /dashboard/hermes-insights.
# Only active when PRX_HERMES_ENABLED=Y. See README → "Hermes can contribute to the KB".
# PRX_HERMES_KB_WRITEBACK_ENABLED=AUTO

# Quick setup/teardown:
#   bash server/integrations/hermes/scripts/install.sh    → enable Hermes mode
#   bash server/integrations/hermes/scripts/uninstall.sh  → revert to standalone

# ────────────────────────────────────────────────────────────
# TELEGRAM (built-in, bi-directional)
# ────────────────────────────────────────────────────────────
# See README → "Telegram — full setup guide" for the BotFather walkthrough.

# PRX_TELEGRAM_ENABLED — master switch for outbound Telegram alerts.
# PRX_TELEGRAM_ENABLED=N

# PRX_TELEGRAM_BOT_TOKEN — token from @BotFather (<numeric-id>:<35-char-string>).
# PRX_TELEGRAM_BOT_TOKEN=

# PRX_TELEGRAM_CHAT_ID — single chat-ID allowlist. Personal IDs are positive
# integers; group IDs start with -100. Used for outbound + inbound.
# PRX_TELEGRAM_CHAT_ID=

# PRX_TELEGRAM_EVENTS — comma-separated event allowlist for outbound alerts.
# Blank = all events. Example: ticket_completed,ticket_failed,hermes_gateway_started
# PRX_TELEGRAM_EVENTS=

# PRX_TELEGRAM_INBOUND_ENABLED — set to Y to accept slash commands from the bot:
# /dev /review /estimate /status /queue /help. AUTO-DISABLED while
# PRX_HERMES_ENABLED=Y (Hermes owns the chat surface in that mode).
# PRX_TELEGRAM_INBOUND_ENABLED=N


# ────────────────────────────────────────────────────────────
# NOTIFICATIONS (optional)
# ────────────────────────────────────────────────────────────
# Email alerts for ticket lifecycle events. Requires PRX_EMAIL_TO to be set.
# Leave PRX_NOTIFY_ENABLED unset or set to N to disable all notifications.

# Enable notifications. Default: N (disabled).
# PRX_NOTIFY_ENABLED=N

# Notification verbosity level:
#   full    → one email per event
#   compact → one summary email per job (queued → completed/failed)
#   urgent  → issues and decision prompts only
#   mute    → all notifications suppressed
# PRX_NOTIFY_LEVEL=compact

# Temporarily mute all notifications for N days (0 = not muted).
# PRX_NOTIFY_MUTE_DAYS=0

# Internal: set by the mute command — do not edit manually.
# PRX_NOTIFY_MUTE_UNTIL=

# Comma-separated list of events to notify on.
# Available events: jira_assigned, ticket_scheduled, ticket_queued,
#   ticket_started, ticket_completed, ticket_failed, ticket_interrupted, poll_ran
# PRX_NOTIFY_EVENTS=jira_assigned,ticket_scheduled,ticket_queued,ticket_started,ticket_completed,ticket_failed,ticket_interrupted,poll_ran


# ────────────────────────────────────────────────────────────
# HEALTH MONITOR — WATCHDOG (optional)
# ────────────────────────────────────────────────────────────
# In-process background thread that polls GET /health on a configurable interval
# and sends an urgent email alert when the server stops responding.
# Requires PRX_EMAIL_TO. Also sends a recovery email when the server comes back.
# Note: as an in-process thread it cannot catch a hard OS kill (SIGKILL / OOM).

# Enable the watchdog. Default: N (disabled).
# PRX_WATCHDOG_ENABLED=N

# Seconds between health checks. Default: 60.
# PRX_WATCHDOG_INTERVAL_SECS=60

# Consecutive failures before sending a DOWN alert. Default: 3.
# PRX_WATCHDOG_FAIL_THRESHOLD=3


# ────────────────────────────────────────────────────────────
# DISK MONITOR (optional)
# ────────────────────────────────────────────────────────────
# In-process background thread that tracks disk space consumed by ~/.prevoyant/.
# Sends an email alert when the folder exceeds the configured size quota.
# Cleanup must be approved via the dashboard — no automatic deletion.

# Enable the disk monitor. Default: N (disabled).
# PRX_DISK_MONITOR_ENABLED=N

# Minutes between disk checks. Default: 60.
# PRX_DISK_MONITOR_INTERVAL_MINS=60

# Max allowed size of ~/.prevoyant/ in MB. The alert fires when the folder
# reaches PRX_DISK_CAPACITY_ALERT_PCT percent of this value.
# Default: 500.
# PRX_PREVOYANT_MAX_SIZE_MB=500

# Percentage of the size quota at which to send an alert email.
# E.g. 80% of 500 MB = alert fires at 400 MB. Default: 80.
# PRX_DISK_CAPACITY_ALERT_PCT=80

# Days between cleanup passes (surfaces a pending-cleanup notice on the dashboard).
# Default: 7.
# PRX_DISK_CLEANUP_INTERVAL_DAYS=7

# ─────────────────────────────────────────────────────────────────
# Ticket Watcher
# Polls watched Jira tickets on a schedule, calls Claude to build a
# progress digest, and emails it. Manage watched tickets at
# /dashboard/watch. State persists across restarts in
# ~/.prevoyant/server/watched-tickets.json.
# ─────────────────────────────────────────────────────────────────

# Enable the ticket watcher background worker.
# Set to Y to activate. Default: N.
# PRX_WATCH_ENABLED=N

# Default poll interval pre-selected when adding a ticket.
# Values: 1h | 1d | 2d | 5d. Default: 1d.
# PRX_WATCH_POLL_INTERVAL=1d

# Default maximum number of polls per ticket (0 = unlimited).
# Pre-filled in the Watch page add form. Default: 0.
# PRX_WATCH_MAX_POLLS=0

# Watch poll log retention — applied during house-cleaning from the Disk Monitor page.
# PRX_WATCH_LOG_KEEP_DAYS: delete log files older than this many days. Default: 30.
# PRX_WATCH_LOG_KEEP_PER_TICKET: keep at most this many log files per ticket (oldest removed first). Default: 10.
# PRX_WATCH_LOG_KEEP_DAYS=30
# PRX_WATCH_LOG_KEEP_PER_TICKET=10


# ────────────────────────────────────────────────────────────
# WHATSAPP NOTIFICATIONS (optional — via WaSenderAPI)
# ────────────────────────────────────────────────────────────
# Sends concise WhatsApp alerts for ticket lifecycle events.
# PDF reports are delivered as encrypted or plain WhatsApp documents.
#
# Sign up at https://wasenderapi.com (free 3-day trial).
# Get your Session API Key from Dashboard → Sessions → API Key.

# Enable WhatsApp notifications. Default: N.
# PRX_WASENDER_ENABLED=N

# Session-specific API Key from WaSenderAPI dashboard.
# PRX_WASENDER_API_KEY=your-session-api-key

# Recipient WhatsApp number (with country code, e.g. +23052xxxxxxx).
# PRX_WASENDER_TO=+23052xxxxxxx

# Public base URL of this server for PDF report delivery (optional).
# When set (and no PDF password), WaSenderAPI fetches the report directly from this server.
# When blank, reports are auto-uploaded to tmpfiles.org (free, 14-day links, no account needed).
# When a PDF password is set, tmpfiles.org is always used regardless of this field.
# PRX_WASENDER_PUBLIC_URL=https://yourserver.com

# PDF report password (optional).
# When set, PDF reports are encrypted with this password before being sent via WhatsApp.
# Recipients must enter this password to open the document.
# Requires qpdf: brew install qpdf (Mac) or apt install qpdf (Linux/WSL).
# PRX_WASENDER_PDF_PASSWORD=

# Comma-separated list of events that trigger a WhatsApp message.
# Leave blank to notify on all enabled events.
# Available: jira_assigned, ticket_queued, ticket_started, ticket_completed,
#   ticket_failed, ticket_interrupted, ticket_scheduled, poll_ran,
#   stage_dev_root_cause, stage_dev_fix, stage_dev_impact, stage_dev_report,
#   stage_review_panel, stage_review_report, stage_est_final, stage_est_report,
#   watch_poll_completed, watch_poll_failed, watch_completed
# PRX_WASENDER_EVENTS=ticket_completed,ticket_failed,stage_dev_report,stage_review_report


# ────────────────────────────────────────────────────────────
# KB FLOW ANALYST (optional)
# ────────────────────────────────────────────────────────────
# An autonomous worker that periodically queries Jira to identify
# which business flows are generating the most incidents/bugs, then
# scans those flows in the codebase and proposes Core Mental Map updates.
# No manual flow configuration required — the agent selects focus areas
# from real incident data.
#
# Runs as a dedicated worker thread in prevoyant-server.
# Proposed contributions are written to ~/.prevoyant/knowledge-buildup/kbflow-pending.md
# as PENDING APPROVAL. The team votes at Step 13j in the next dev session.
# Nothing is written to core-mental-map/ without unanimous team approval.
#
# A full run log (date, flows analysed, proposals, approval status)
# is maintained in ~/.prevoyant/knowledge-buildup/kbflow-sessions.md.
#
# Requires prevoyant-server to be running.
# Requires JIRA_URL + JIRA_USERNAME + JIRA_API_TOKEN and PRX_REPO_DIR.

# Enable the KB Flow Analyst worker. Default: N (disabled).
# PRX_KBFLOW_ENABLED=N

# Days between analysis runs. Default: 7. Minimum: 1.
# Fractional values work: 0.5 = every 12 hours.
# PRX_KBFLOW_INTERVAL_DAYS=7

# Days of Jira ticket history to scan when identifying high-frequency flows.
# A larger window finds structural patterns; a smaller one tracks recent spikes.
# Default: 30.
# PRX_KBFLOW_LOOKBACK_DAYS=30

# Maximum number of business flows to analyse per run. Keeps each run focused.
# Default: 3.
# PRX_KBFLOW_MAX_FLOWS=3

# Maximum hours the Claude CLI process is allowed to run before being killed.
# Prevents a hung scan from blocking the worker indefinitely. Minimum: 0.25 (15 min).
# Default: 2.
# PRX_KBFLOW_TIMEOUT_HOURS=2

# Days before a reminder email is sent when pending proposals have not been reviewed.
# The nudge fires at the next hourly tick if proposals are older than this threshold.
# Set 0 to disable. Default: 7.
# PRX_KBFLOW_REVIEW_NUDGE_DAYS=7

# ────────────────────────────────────────────────────────────
# MEMORY PATTERN MINER (optional)
# ────────────────────────────────────────────────────────────
# Periodically scans agent persona memory files for learnings that recur across
# 3+ distinct tickets and emits pattern proposals to
# ~/.prevoyant/knowledge-buildup/pattern-proposals.md (PENDING APPROVAL).
# A human or the Step 13j review process must promote them to shared/patterns.md.

# Enable pattern mining. Default: N.
# PRX_PATTERN_MINER_ENABLED=N

# Scan interval in days. Default: 7.
# PRX_PATTERN_MINER_INTERVAL_DAYS=7

# Minimum number of distinct tickets a learning must appear in before it is
# considered a pattern. Lower values find more proposals; higher values are stricter.
# Default: 3 (minimum enforced: 2).
# PRX_PATTERN_MINER_MIN_TICKETS=3

# Maximum proposals written per run. Prevents the output file growing unbounded.
# Default: 20.
# PRX_PATTERN_MINER_MAX_PROPOSALS=20

# ────────────────────────────────────────────────────────────
# KB STALENESS SCANNER (optional)
# ────────────────────────────────────────────────────────────
# Periodically walks all .md files in the knowledge base, extracts file:line
# references, and checks whether those files still exist in the source repo at
# the expected depth. Stale refs are written to
# ~/.prevoyant/knowledge-buildup/stale-refs.md and a machine-readable JSON
# report to ~/.prevoyant/server/kb-staleness-report.json.
# Requires PRX_REPO_DIR (or PRX_SOURCE_REPO_DIR) to be set.

# Enable staleness scanning. Default: N.
# PRX_STALENESS_ENABLED=N

# Scan interval in days. Default: 7.
# PRX_STALENESS_INTERVAL_DAYS=7

# ────────────────────────────────────────────────────────────
# STALE BRANCH DETECTOR (optional)
# ────────────────────────────────────────────────────────────
# Periodically lists feature/fix branches in PRX_REPO_DIR, cross-references each
# Jira ticket key against KB session records, and checks Jira's development
# panel for any linked PR. Branches whose ticket has a completed KB session but
# no PR (and no commit activity for the configured number of days) are flagged
# in ~/.prevoyant/knowledge-buildup/stale-branches.md and a machine-readable
# report to ~/.prevoyant/server/stale-branches-report.json.
# Requires PRX_REPO_DIR and Jira credentials (JIRA_URL, JIRA_USERNAME,
# JIRA_API_TOKEN). If Jira is unavailable, the PR check degrades gracefully and
# entries are not flagged as stale.

# Enable stale branch detection. Default: N.
# PRX_STALE_BRANCH_ENABLED=N

# Branches with no commit activity for this many days are considered stale.
# Default: 14.
# PRX_STALE_BRANCH_DAYS=14

# Scan interval in days. Fractional values supported. Default: 1.
# PRX_STALE_BRANCH_INTERVAL_DAYS=1

# ────────────────────────────────────────────────────────────
# DECISION-OUTCOME LINKER (optional)
# ────────────────────────────────────────────────────────────
# Background worker that joins KB decision entries (shared/decisions.md,
# shared/skill-changelog.md, lessons-learned/*.md) against recent agent retros
# and grades each decision CONFIRMED / CONTRADICTED / PENDING.  Proposals are
# written to ~/.prevoyant/knowledge-buildup/decision-outcomes.md for review.
# Nothing is written to the KB directly.

# Enable decision-outcome linkage. Default: N.
# PRX_DECISION_OUTCOME_ENABLED=N

# Scan interval in days. Fractional values supported. Default: 7.
# PRX_DECISION_OUTCOME_INTERVAL_DAYS=7

# Only consider retros modified within this many days. Default: 90.
# PRX_DECISION_OUTCOME_LOOKBACK_DAYS=90

# Minimum confirmations required (with zero contradictions) to grade CONFIRMED.
# Default: 2.
# PRX_DECISION_OUTCOME_MIN_EVIDENCE=2

# ────────────────────────────────────────────────────────────
# CO-CHANGE INDEX (used by the conflict checker — optional tuning)
# ────────────────────────────────────────────────────────────
# When a new ticket is enqueued the conflict checker also runs a co-change
# prediction pass to surface "silent" conflicts — files that don't directly
# overlap but historically co-change with the other ticket's files.  The
# co-change index is cached to ~/.prevoyant/server/co-change-cache.json.

# How many days of history to mine.  Default: 180.
# PRX_COCHANGE_WINDOW_DAYS=180

# Cache TTL in days — rebuild beyond this age.  Default: 7.
# PRX_COCHANGE_CACHE_TTL_DAYS=7

# ────────────────────────────────────────────────────────────
# CORTEX — Always-on Intelligence Layer (optional)
# ────────────────────────────────────────────────────────────
# Cortex sits on top of the KB and synthesises accumulated knowledge into a
# curated set of fact files at ~/.prevoyant/cortex/facts/*.md.  Agents read
# those files in Step 0 of the dev skill instead of trawling the raw KB on
# every session.  When enabled, the worker watches the KB filesystem and
# (optionally) runs repowise (https://github.com/repowise-dev/repowise) on a
# schedule to refresh the codebase dependency graph + auto-wiki.
#
# A dedicated dashboard page at /dashboard/cortex displays every fact file.
# Cortex files can be included in backup/export.  When PRX_CORTEX_ENABLED=Y
# the dashboard header shows an animated revolving brain badge.

# Enable cortex worker. Default: N.
# PRX_CORTEX_ENABLED=N

# Wait this many seconds after the last KB change before re-synthesising.
# Default: 30.
# PRX_CORTEX_DEBOUNCE_SECS=30

# Heartbeat resync interval in hours — periodic safety net if fs.watch misses
# a change. Default: 6.
# PRX_CORTEX_RESYNC_HOURS=6

# ── Repowise sub-integration ─────────────────────────────────────────────────
# Run `repowise update` as part of each cortex pass.  Requires Python 3.11+
# and the `repowise` PyPI package (install via the button on the Cortex page,
# or `pipx install repowise`).

# Enable repowise integration. Default: N.
# PRX_REPOWISE_ENABLED=N

# How often to run repowise (days).  Fractional values supported.  Default: 1.
# PRX_REPOWISE_INTERVAL_DAYS=1

# Override the command/path used to invoke repowise. Default: `repowise` on PATH.
# PRX_REPOWISE_PATH=repowise

# If Y, the plugin SessionStart hook runs the cross-platform installer if
# repowise is missing.  Default: N (no implicit installs).
# PRX_REPOWISE_AUTO_INSTALL=N
