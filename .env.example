# ============================================================
# Prevoyant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Claude Code loads .env automatically from the project root,
# so every tool (the skill, MCP server, polling script) picks
# up credentials from this one file.
#
# .env is listed in .gitignore and will never be committed.
# Share secrets with teammates via 1Password or your secrets manager.
# ============================================================


# ────────────────────────────────────────────────────────────
# REPOSITORY (required)
# ────────────────────────────────────────────────────────────
# Absolute path to the local clone of the codebase you are
# working on. The skill creates branches and searches files here.

PRX_REPO_DIR=/absolute/path/to/your/repo


# ────────────────────────────────────────────────────────────
# JIRA (required)
# ────────────────────────────────────────────────────────────
# The MCP server (mcp-atlassian) and the polling script both
# read these from the environment — no other config file needed.
#
# Get your API token: https://id.atlassian.com/manage-profile/security/api-tokens

JIRA_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=firstname.lastname@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token-here


# ────────────────────────────────────────────────────────────
# KNOWLEDGE BASE (optional)
# ────────────────────────────────────────────────────────────
# Leave PRX_KB_MODE unset for single-machine use (local mode, zero setup).
# Set to "distributed" to share the KB across your team via a private git repo.

# Optional: hosted URL of your codebase (e.g. GitHub / Bitbucket / GitLab).
# Used to cross-check KB file:line references against the live branch.
# Omit to skip the cross-check.
# PRX_SOURCE_REPO_URL=https://github.com/myorg/myrepo

# "local" (default) or "distributed"
# PRX_KB_MODE=local

# Local mode only: override the default KB path.
# Default: $HOME/.prevoyant/knowledge-base
# PRX_KNOWLEDGE_DIR=/your/custom/kb/path

# Distributed mode only: URL of your team's private KB git repository.
# Required when PRX_KB_MODE=distributed.
# PRX_KB_REPO=git@github.com:yourorg/team-kb.git

# Distributed mode only: local clone path for the KB repo.
# Default: $HOME/.prevoyant/kb
# PRX_KB_LOCAL_CLONE=$HOME/.prevoyant/kb

# Distributed mode only: AES-256-CBC encryption passphrase.
# Optional — omit to push plain Markdown (fine when the repo is private).
# If set, all KB files are encrypted before each push and decrypted at session start.
# Never commit this value. Share via 1Password or your secrets manager.
# PRX_KB_KEY=your-strong-secret-passphrase

# ── Real-time KB sync — Redis doorbell, Git mail carrier ─────────────────────
# Propagates KB updates across all connected machines the moment a session ends.
# Flow: Machine A finishes → git push (KB files, private repo) → XADD to Upstash
#       (tiny ~100-byte notification: machine name, ticket key, commit hash).
#       Every other machine is polling XREAD and immediately does git pull --rebase.
#       No KB content ever touches Redis. Git carries the actual files.
# Requires PRX_KB_MODE=distributed and Upstash credentials below.
# Sign up free at https://upstash.com/ — free tier is more than enough.

# Enable real-time KB sync. Default: N (disabled).
# PRX_REALTIME_KB_SYNC=N

# Upstash Redis REST URL. Copy from console.upstash.com → your database → REST API.
# PRX_UPSTASH_REDIS_URL=https://your-endpoint.upstash.io

# Upstash Redis REST token. Copy from the same REST API panel. Never commit this.
# PRX_UPSTASH_REDIS_TOKEN=your-token-here

# Override the machine name used in sync notifications. Defaults to os.hostname().
# Useful in Docker / cloud VMs where the hostname is unstable across restarts.
# PRX_KB_SYNC_MACHINE=my-machine-name

# How often each machine polls Redis for new KB notifications. Default: 10 (seconds).
# PRX_KB_SYNC_POLL_SECS=10

# What triggers an outbound KB notification on this machine:
#   session    — SKILL.md writes ~/.prevoyant/.kb-updated after git push → XADD.
#                kb-sync.js never touches git. Clean handshake between bash and Node.
#   filesystem — Watches the KB dir for .md file changes (manual edits outside sessions).
#                kb-sync.js does git add / commit / push → XADD when changes are detected.
#   both       — Both triggers active simultaneously.
# Default: session
# PRX_KB_SYNC_TRIGGER=session

# How many seconds to wait after the last filesystem change before committing and pushing.
# Only applies when PRX_KB_SYNC_TRIGGER=filesystem or both. Default: 3.
# PRX_KB_SYNC_DEBOUNCE_SECS=3


# ────────────────────────────────────────────────────────────
# REPORT OUTPUT (optional)
# ────────────────────────────────────────────────────────────
# Folder where PDF/HTML analysis reports are saved.
# Default: $HOME/.prevoyant/reports
# The folder is created automatically if it does not exist.

# CLAUDE_REPORT_DIR=/your/custom/reports/path


# ────────────────────────────────────────────────────────────
# AUTOMATION (optional)
# ────────────────────────────────────────────────────────────
# Set AUTO_MODE=Y to run the full workflow without any interactive
# prompts, confirmation gates, or permission asks. Safe defaults
# are applied at every gate. The fix is proposed AND automatically
# applied to the newly created feature branch.
# Default: N (interactive mode — prompts at each gate).

# AUTO_MODE=N

# Set FORCE_FULL_RUN=Y to force every step to execute in full even when
# the ticket has been analysed in a prior session. Without this flag the
# skill may condense steps 1–12 into a summary on repeat runs.
# Useful when replaying a ticket to get a completely fresh analysis.
# Default: N

# FORCE_FULL_RUN=N


# ────────────────────────────────────────────────────────────
# OUTPUT VERBOSITY (optional)
# ────────────────────────────────────────────────────────────
# Controls how much panel dialogue appears in the terminal.
# The PDF report always contains full content regardless of this setting.
#   full    → all panel dialogue, debate rounds, check-ins (default)
#   compact → structured blocks intact; narrative condensed to bullets
#   minimal → structured blocks only; no panel narrative

# PRX_REPORT_VERBOSITY=full


# ────────────────────────────────────────────────────────────
# JIRA PROJECT SCOPE (optional)
# ────────────────────────────────────────────────────────────
# Jira project key to scope ticket polling.
# When set, poll-jira.sh adds `project = {PRX_JIRA_PROJECT}` to the JQL
# so only tickets from that project trigger automated analysis.
# Omit to poll all projects assigned to currentUser().

# PRX_JIRA_PROJECT=IV


# ────────────────────────────────────────────────────────────
# ATTACHMENT SIZE LIMIT (optional)
# ────────────────────────────────────────────────────────────
# Maximum size in MB for non-image attachments (logs, dumps, XML, etc.).
# Set to 0 (or leave unset) for no limit — all attachments are downloaded
# and analysed regardless of size.
# Images/screenshots are always read regardless of this setting.
# Example: PRX_ATTACHMENT_MAX_MB=25  (skip non-image files > 25 MB)

# PRX_ATTACHMENT_MAX_MB=0


# ────────────────────────────────────────────────────────────
# EMAIL DELIVERY (optional)
# ────────────────────────────────────────────────────────────
# When PRX_EMAIL_TO is set, the analysis/review report is emailed
# automatically after it is saved, and a notification is sent for
# each newly assigned Jira ticket (via the polling script).
# Uses Python 3's built-in smtplib — no extra packages needed.
#
# Leave PRX_EMAIL_TO unset (or remove the line) to disable email entirely.

# Recipient address. Set this to enable email delivery.
# PRX_EMAIL_TO=recipient@example.com

# SMTP server hostname.
# Gmail:       smtp.gmail.com
# Outlook/365: smtp.office365.com
# PRX_SMTP_HOST=smtp.gmail.com

# SMTP port. Default: 587 (STARTTLS). Use 465 for SSL-only servers.
# PRX_SMTP_PORT=587

# SMTP login username (usually your email address).
# PRX_SMTP_USER=you@gmail.com

# SMTP password or app password.
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
#        (required when 2-Step Verification is enabled)
# Outlook/365: use your normal Microsoft 365 password (or app password if MFA is enforced)
# PRX_SMTP_PASS=your-app-password-here


# ────────────────────────────────────────────────────────────
# BRYAN — SCRUM MASTER / SKILL UPGRADES (optional)
# ────────────────────────────────────────────────────────────
# Bryan observes every session and proposes one SKILL.md improvement
# per session (Step 14 / R10). Disabled by default — set PRX_INCLUDE_SM_IN_SESSIONS_ENABLED=Y
# to activate. After unanimous team consensus, the change is queued.
# Once PRX_SKILL_UPGRADE_MIN_SESSIONS sessions with an approved change
# have accumulated, Bryan commits and pushes them to the plugin repo's main branch.

# Enable Bryan's retrospective. Default: N (disabled).
# PRX_INCLUDE_SM_IN_SESSIONS_ENABLED=N

# Number of sessions before pushing approved changes to main. Default: 3.
# Set to 1 to push after every approved session.
# PRX_SKILL_UPGRADE_MIN_SESSIONS=3

# Sessions between full SKILL.md compaction passes.
# On compaction sessions Bryan deep-reviews the entire file to eliminate
# redundancy and compress verbose prose. Requires all five team members to approve.
# Default: 10
# PRX_SKILL_COMPACTION_INTERVAL=10

# Monthly Claude subscription budget in USD.
# Actual token costs are measured using ccusage (https://www.npmjs.com/package/ccusage),
# which reads Claude Code's local JSONL logs — no network call, no auth needed.
# At every session start, scripts/check-budget.sh runs ccusage and injects the
# current month's actual spend into Claude's context, warning at ⚠️ >80% and ❌ ≥100%.
# Step 11 / R7 also uses ccusage to report the per-session cost delta.
# Budget resets on the 1st of each calendar month.
# Default: 20.00 (standard Claude Pro monthly subscription)

# PRX_MONTHLY_BUDGET=20.00

# PRX_JOB_TIMEOUT_MINS — kill any job still running after this many minutes.
# Set to 0 (default) to disable. Useful to prevent runaway sessions eating budget.
# PRX_JOB_TIMEOUT_MINS=0

# PRX_WEBHOOK_URL — POST job lifecycle events to this URL (Slack/Discord/Teams/custom).
# Leave unset to disable.
# PRX_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# PRX_WEBHOOK_EVENTS — comma-separated list of event types that trigger the webhook.
# Default: ticket_completed,ticket_failed,ticket_interrupted
# PRX_WEBHOOK_EVENTS=ticket_completed,ticket_failed,ticket_interrupted


# ────────────────────────────────────────────────────────────
# AMBIENT AGENT — WEBHOOK SERVER (optional)
# ────────────────────────────────────────────────────────────
# The Node.js server in server/ provides two capabilities:
#   1. Real-time: receives Jira webhook events and triggers analysis immediately.
#   2. Scheduled: runs poll-jira.sh on a configurable day interval as a fallback.
#
# To start the server:
#   cd server && npm install && npm start
#
# WEBHOOK_PORT — port the Express server listens on. Default: 3000.
# WEBHOOK_PORT=3000

# WEBHOOK_SECRET — token appended to the webhook URL you register in Jira.
# In Jira: Project settings → Webhooks → URL: http://your-server:3000/jira-events?token=YOUR_SECRET
# Leave empty to skip token validation (only safe on a private network).
# WEBHOOK_SECRET=your-strong-secret-here

# WEBHOOK_POLL_INTERVAL_DAYS — run poll-jira.sh every N days as a scheduled fallback.
# Set to 0 (or leave unset) to disable scheduled polling entirely.
# Fractional values work: 0.5 = every 12 hours, 7 = weekly.
# WEBHOOK_POLL_INTERVAL_DAYS=1


# ────────────────────────────────────────────────────────────
# NOTIFICATIONS (optional)
# ────────────────────────────────────────────────────────────
# Email alerts for ticket lifecycle events. Requires PRX_EMAIL_TO to be set.
# Leave PRX_NOTIFY_ENABLED unset or set to N to disable all notifications.

# Enable notifications. Default: N (disabled).
# PRX_NOTIFY_ENABLED=N

# Notification verbosity level:
#   full    → one email per event
#   compact → one summary email per job (queued → completed/failed)
#   urgent  → issues and decision prompts only
#   mute    → all notifications suppressed
# PRX_NOTIFY_LEVEL=compact

# Temporarily mute all notifications for N days (0 = not muted).
# PRX_NOTIFY_MUTE_DAYS=0

# Internal: set by the mute command — do not edit manually.
# PRX_NOTIFY_MUTE_UNTIL=

# Comma-separated list of events to notify on.
# Available events: jira_assigned, ticket_scheduled, ticket_queued,
#   ticket_started, ticket_completed, ticket_failed, ticket_interrupted, poll_ran
# PRX_NOTIFY_EVENTS=jira_assigned,ticket_scheduled,ticket_queued,ticket_started,ticket_completed,ticket_failed,ticket_interrupted,poll_ran


# ────────────────────────────────────────────────────────────
# HEALTH MONITOR — WATCHDOG (optional)
# ────────────────────────────────────────────────────────────
# In-process background thread that polls GET /health on a configurable interval
# and sends an urgent email alert when the server stops responding.
# Requires PRX_EMAIL_TO. Also sends a recovery email when the server comes back.
# Note: as an in-process thread it cannot catch a hard OS kill (SIGKILL / OOM).

# Enable the watchdog. Default: N (disabled).
# PRX_WATCHDOG_ENABLED=N

# Seconds between health checks. Default: 60.
# PRX_WATCHDOG_INTERVAL_SECS=60

# Consecutive failures before sending a DOWN alert. Default: 3.
# PRX_WATCHDOG_FAIL_THRESHOLD=3


# ────────────────────────────────────────────────────────────
# DISK MONITOR (optional)
# ────────────────────────────────────────────────────────────
# In-process background thread that tracks disk space consumed by ~/.prevoyant/.
# Sends an email alert when the folder exceeds the configured size quota.
# Cleanup must be approved via the dashboard — no automatic deletion.

# Enable the disk monitor. Default: N (disabled).
# PRX_DISK_MONITOR_ENABLED=N

# Minutes between disk checks. Default: 60.
# PRX_DISK_MONITOR_INTERVAL_MINS=60

# Max allowed size of ~/.prevoyant/ in MB. The alert fires when the folder
# reaches PRX_DISK_CAPACITY_ALERT_PCT percent of this value.
# Default: 500.
# PRX_PREVOYANT_MAX_SIZE_MB=500

# Percentage of the size quota at which to send an alert email.
# E.g. 80% of 500 MB = alert fires at 400 MB. Default: 80.
# PRX_DISK_CAPACITY_ALERT_PCT=80

# Days between cleanup passes (surfaces a pending-cleanup notice on the dashboard).
# Default: 7.
# PRX_DISK_CLEANUP_INTERVAL_DAYS=7

# ─────────────────────────────────────────────────────────────────
# Ticket Watcher
# Polls watched Jira tickets on a schedule, calls Claude to build a
# progress digest, and emails it. Manage watched tickets at
# /dashboard/watch. State persists across restarts in
# ~/.prevoyant/server/watched-tickets.json.
# ─────────────────────────────────────────────────────────────────

# Enable the ticket watcher background worker.
# Set to Y to activate. Default: N.
# PRX_WATCH_ENABLED=N

# Default poll interval pre-selected when adding a ticket.
# Values: 1h | 1d | 2d | 5d. Default: 1d.
# PRX_WATCH_POLL_INTERVAL=1d

# Default maximum number of polls per ticket (0 = unlimited).
# Pre-filled in the Watch page add form. Default: 0.
# PRX_WATCH_MAX_POLLS=0

# Watch poll log retention — applied during house-cleaning from the Disk Monitor page.
# PRX_WATCH_LOG_KEEP_DAYS: delete log files older than this many days. Default: 30.
# PRX_WATCH_LOG_KEEP_PER_TICKET: keep at most this many log files per ticket (oldest removed first). Default: 10.
# PRX_WATCH_LOG_KEEP_DAYS=30
# PRX_WATCH_LOG_KEEP_PER_TICKET=10
